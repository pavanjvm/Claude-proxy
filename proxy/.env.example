# OpenCode Zen Go API key (required)
# Obtain from https://opencode.ai/zen
OPENCODE_API_KEY=your-opencode-api-key-here

# Optional: Override the upstream OpenAI-compatible endpoint
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Optional: Override the upstream model name
OPENCODE_MODEL=deepseek-v4-flash

# Optional: Request timeout in seconds (default 120)
UPSTREAM_TIMEOUT=120

# Optional: Bind address and port
HOST=0.0.0.0
PORT=8080

# Optional: Log level (debug, info, warning, error)
LOG_LEVEL=info
