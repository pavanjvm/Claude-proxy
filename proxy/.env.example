# ---- Shared OpenCode Zen Go settings (used for every model below) ----
# Obtain an API key from https://opencode.ai/zen
OPENCODE_API_KEY=your-opencode-api-key-here
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Per-model routing. Each entry maps an Anthropic-facing model name to an
# OpenCode Go upstream model slug. The same OPENCODE_API_KEY is reused.
#
# Format:   MODEL_<N>_ALIAS=<name-claude-code-sends>
#           MODEL_<N>_UPSTREAM=<slug-opencode-accepts>
#           MODEL_<N>_DISPLAY=<human-friendly-label>   (optional)
#
# The first model in this list is the default if a request omits `model`
# or sends an unknown one.

# Model 1: DeepSeek V4 Flash (cheap, fast, high volume tier)
MODEL_1_ALIAS=deepseek
MODEL_1_UPSTREAM=deepseek-v4-flash
MODEL_1_DISPLAY=DeepSeek V4 Flash (via OpenCode Go)

# Model 2: MiniMax M3 (standard tier workhorse, 59% SWE-Pro)
MODEL_2_ALIAS=minimax
MODEL_2_UPSTREAM=minimax-m3
MODEL_2_DISPLAY=MiniMax M3 (via OpenCode Go)

# Add more by incrementing the index. Examples:
# MODEL_3_ALIAS=kimi
# MODEL_3_UPSTREAM=kimi-k2.6
# MODEL_3_DISPLAY=Kimi K2.6 (via OpenCode Go)

# ---- Optional ----
UPSTREAM_TIMEOUT=120
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
